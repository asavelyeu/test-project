{
  "name": "shared-ui-angular",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/ui-angular/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": ["scope:shared", "type:ui"],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/shared/ui-angular/ng-package.json",
        "tsConfig": "libs/shared/ui-angular/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/shared/ui-angular/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/shared/ui-angular/jest.config.cts",
        "tsConfig": "libs/shared/ui-angular/tsconfig.spec.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "configDir": "libs/shared/ui-angular/.storybook",
        "browserTarget": "shared-ui-angular:build:development",
        "compodoc": false,
        "port": 4400
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": ["{projectRoot}/storybook-static"],
      "options": {
        "configDir": "libs/shared/ui-angular/.storybook",
        "browserTarget": "shared-ui-angular:build:production",
        "compodoc": false,
        "outputDir": "libs/shared/ui-angular/storybook-static"
      },
      "cache": true
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/shared/ui-angular",
        "command": "test-storybook"
      }
    },
    "static-storybook": {
      "dependsOn": ["build-storybook"],
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "build-storybook",
        "staticFilePath": "libs/shared/ui-angular/storybook-static"
      }
    }
  }
}
