{
  "servers": {
    "nx": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "nx-mcp@latest"]
    },
    "jira": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-atlassian"],
      "env": {
        "JIRA_URL": "${input:jiraUrl}",
        "JIRA_USERNAME": "${input:jiraUsername}",
        "JIRA_API_TOKEN": "${input:jiraApiToken}"
      }
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "figma": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "figma-mcp"],
      "env": {
        "FIGMA_API_KEY": "${env:TEST_PROJECT_FIGMA_ACCESS_TOKEN}"
      }
    },
    "confluence": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-atlassian-confluence"],
      "env": {
        "CONFLUENCE_URL": "${env:CONFLUENCE_BASE_URL}",
        "CONFLUENCE_EMAIL": "${env:JIRA_EMAIL}",
        "CONFLUENCE_API_TOKEN": "${env:JIRA_API_TOKEN}"
      }
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${env:GITHUB_TOKEN}"
      }
    }
  },
  "inputs": [
    {
      "id": "jiraUrl",
      "type": "promptString",
      "description": "Jira instance URL (e.g. https://yourcompany.atlassian.net)"
    },
    {
      "id": "jiraUsername",
      "type": "promptString",
      "description": "Jira username (email)"
    },
    {
      "id": "jiraApiToken",
      "type": "promptString",
      "description": "Jira API Token",
      "password": true
    },
    {
      "id": "figmaAccessToken",
      "type": "promptString",
      "description": "Figma Personal Access Token",
      "password": true
    }
  ]
}
